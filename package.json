{
  "name": "lab-budget-manager",
  "version": "1.0.0",
  "scripts": {
    "clean": "rimraf node_modules frontend/node_modules backend/node_modules",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "reinstall": "npm run clean && npm run install:all",
    "dev": "concurrently \"npm --prefix frontend run dev\" \"npm --prefix backend run dev\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nick-mama/lab-budget-manager.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nick-mama/lab-budget-manager/issues"
  },
  "homepage": "https://github.com/nick-mama/lab-budget-manager#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "next": "16.2.3"
  }
}
